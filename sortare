//merge sort
int x[100],n;
void divizeaza (int s, int d, int&m)
    {
        m=(s+d)/2;
    }
void interclaseaza (int s, int d, int m)
{
    int j=s, j=m+1, k=1, v[100];
    while (i<=m && j<=d)
    {
        if (x[i]<x[j])
        {
            v[k]=x[i];
            i++;
        }
        else
        {
            v[k]=x[j];
            j++;
        }
        k++;
    if(i<=m)
        while(j<=m)
        {
            v[k]=x[i];
            i++;
